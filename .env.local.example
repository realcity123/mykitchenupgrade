# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Make.com lead webhook URL
MAKE_LEAD_WEBHOOK_URL=https://hook.us1.make.com/xxxx

# Blog webhook secret (set same value in Make.com)
WEBHOOK_SECRET=your-secret-here

# Vercel deploy hook (for blog auto-redeploy)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/xxxx
